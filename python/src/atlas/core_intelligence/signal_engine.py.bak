"""
Signal Composition Engine
==========================
Aggregates signals from multiple sources (technical, derivatives, ML engines)
into a unified trading signal with confidence score.

Copyright (c) 2026 M&C. All rights reserved.
"""

import logging
from typing import Any, Dict, List, Optional

import numpy as np

logger = logging.getLogger("atlas.signals")


class Signal:
    """Represents a single trading signal from any source."""

    def __init__(
        self,
        source: str,
        direction: str,
        strength: float,
        confidence: float,
        metadata: Optional[Dict] = None,
    ):
        assert direction in ("long", "short", "neutral"), f"Invalid direction: {direction}"
        assert 0 <= strength <= 1, f"Strength must be 0-1, got {strength}"
        assert 0 <= confidence <= 1, f"Confidence must be 0-1, got {confidence}"

        self.source = source
        self.direction = direction
        self.strength = strength
        self.confidence = confidence
        self.metadata = metadata or {}

    def to_numeric(self) -> float:
        """Convert to -1 (short) to +1 (long) scale."""
        if self.direction == "long":
            return self.strength * self.confidence
        elif self.direction == "short":
            return -self.strength * self.confidence
        return 0.0

    def to_dict(self) -> Dict[str, Any]:
        return {
            "source": self.source,
            "direction": self.direction,
            "strength": self.strength,
            "confidence": self.confidence,
            "numeric": self.to_numeric(),
            "metadata": self.metadata,
        }


class DynamicWeights:
    """
    Dynamically adjust signal weights based on market regime and historical accuracy.
    """

    # Default weights by source category
    DEFAULT_WEIGHTS = {
        "technical": 0.25,
        "momentum": 0.20,
        "derivatives": 0.20,
        "ml_model": 0.15,
        "microstructure": 0.10,
        "sentiment": 0.10,
    }

    def __init__(self, base_weights: Optional[Dict[str, float]] = None):
        self.weights = base_weights or dict(self.DEFAULT_WEIGHTS)
        self._normalize()

    def _normalize(self):
        """Ensure weights sum to 1."""
        total = sum(self.weights.values())
        if total > 0:
            self.weights = {k: v / total for k, v in self.weights.items()}

    def get_weight(self, source: str) -> float:
        """Get weight for a source, defaulting to equal weight."""
        # Try exact match, then category match
        if source in self.weights:
            return self.weights[source]
        for category in self.DEFAULT_WEIGHTS:
            if category in source.lower():
                return self.weights.get(category, 0.1)
        return 0.1  # Unknown sources get low weight

    def adjust_for_regime(self, regime: str):
        """
        Adjust weights based on detected market regime.

        In trending markets: boost technical/momentum
        In ranging markets: boost mean-reversion/microstructure
        In volatile markets: boost risk/derivatives signals
        """
        if regime == "trending":
            self.weights["technical"] = 0.35
            self.weights["momentum"] = 0.25
            self.weights["microstructure"] = 0.05
        elif regime == "ranging":
            self.weights["technical"] = 0.15
            self.weights["momentum"] = 0.10
            self.weights["microstructure"] = 0.25
        elif regime == "volatile":
            self.weights["derivatives"] = 0.30
            self.weights["sentiment"] = 0.20
            self.weights["technical"] = 0.15
        self._normalize()


class ConflictResolver:
    """
    Resolves conflicts when signals disagree.
    """

    def __init__(self, agreement_threshold: float = 0.6):
        self.agreement_threshold = agreement_threshold

    def resolve(self, signals: List[Signal]) -> Dict[str, Any]:
        """
        Analyze agreement/disagreement among signals.
        """
        if not signals:
            return {"consensus": "no_signals", "agreement": 0.0}

        directions = [s.direction for s in signals]
        long_count = directions.count("long")
        short_count = directions.count("short")
        total = len(signals)

        long_pct = long_count / total
        short_pct = short_count / total

        if long_pct >= self.agreement_threshold:
            consensus = "long"
            agreement = long_pct
        elif short_pct >= self.agreement_threshold:
            consensus = "short"
            agreement = short_pct
        else:
            consensus = "conflicted"
            agreement = max(long_pct, short_pct)

        return {
            "consensus": consensus,
            "agreement": round(agreement, 3),
            "long_count": long_count,
            "short_count": short_count,
            "neutral_count": total - long_count - short_count,
            "is_conflicted": consensus == "conflicted",
        }


class SignalEngine:
    """
    Main signal composition engine.
    Aggregates multiple signals into a unified output.
    """

    def __init__(
        self,
        weights: Optional[DynamicWeights] = None,
        conflict_resolver: Optional[ConflictResolver] = None,
    ):
        self.weights = weights or DynamicWeights()
        self.resolver = conflict_resolver or ConflictResolver()

    def compose(self, signals: List[Signal]) -> Dict[str, Any]:
        """
        Compose multiple signals into unified trading signal.

        Returns:
            {
                "direction": "long" | "short" | "neutral",
                "strength": 0.0-1.0,
                "confidence": 0.0-1.0,
                "composite_score": -1.0 to +1.0,
                "conflict": {...},
                "signals": [...]
            }
        """
        if not signals:
            return {
                "direction": "neutral",
                "strength": 0.0,
                "confidence": 0.0,
                "composite_score": 0.0,
                "conflict": {"consensus": "no_signals"},
                "signals": [],
            }

        # Weighted composite score
        weighted_sum = 0.0
        weight_total = 0.0

        for sig in signals:
            w = self.weights.get_weight(sig.source)
            weighted_sum += sig.to_numeric() * w
            weight_total += w

        composite = weighted_sum / weight_total if weight_total > 0 else 0.0

        # Direction from composite
        if composite > 0.1:
            direction = "long"
        elif composite < -0.1:
            direction = "short"
        else:
            direction = "neutral"

        # Strength = magnitude of composite
        strength = min(1.0, abs(composite))

        # Confidence = agreement among signals * average individual confidence
        conflict = self.resolver.resolve(signals)
        avg_confidence = np.mean([s.confidence for s in signals])
        final_confidence = float(conflict["agreement"] * avg_confidence)

        # If conflicted, reduce confidence
        if conflict["is_conflicted"]:
            final_confidence *= 0.5

        return {
            "direction": direction,
            "strength": round(strength, 3),
            "confidence": round(final_confidence, 3),
            "composite_score": round(composite, 4),
            "conflict": conflict,
            "signals": [s.to_dict() for s in signals],
            "weights_used": dict(self.weights.weights),
        }
