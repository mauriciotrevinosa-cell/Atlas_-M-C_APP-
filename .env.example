# ARIA Configuration - AUTONOMOUS EDITION

# ============================================
# LLM Backend (choose one)
# ============================================
# ollama  = Local, free, private (DEFAULT)
# anthropic = Cloud, paid, requires API key
# openai = Cloud, paid, requires API key
ARIA_LLM_BACKEND=ollama

# ============================================
# Ollama Settings (LOCAL - No API key needed)
# ============================================
OLLAMA_HOST=http://localhost:11434
OLLAMA_MODEL=llama3.1

# ============================================
# Cloud APIs (OPTIONAL - only if you want cloud)
# ============================================
# ANTHROPIC_API_KEY=sk-ant-your-key-here
# OPENAI_API_KEY=sk-proj-your-key-here

# ============================================
# General Settings
# ============================================
ARIA_MAX_TOKENS=4096
ARIA_TEMPERATURE=0.7
ARIA_VOICE_MODE=basic
ARIA_MEMORY_TYPE=local
